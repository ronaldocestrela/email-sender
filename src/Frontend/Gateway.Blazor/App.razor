<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <div class="container my-5">
                        <div class="glass-panel text-center alert-premium alert-premium-danger">
                            <span>Acesso negado. Você precisa efetuar o login com uma conta autorizada para visualizar esta página.</span>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Não Encontrado</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="container my-5">
                    <div class="glass-panel text-center alert-premium alert-premium-danger">
                        <span>Ops! A página solicitada não foi encontrada.</span>
                    </div>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
