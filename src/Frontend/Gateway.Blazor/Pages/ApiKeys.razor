@page "/api-keys"
@attribute [Authorize]
@using Gateway.Blazor.Models
@using System.Globalization

<PageTitle>Chaves de API - Email Sender</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <h1 class="page-title">Chaves de API</h1>
        <p class="text-secondary">Gerencie suas chaves de acesso externas para integração com sistemas legados</p>
    </div>
</div>

<div class="row g-4">
    <!-- Lista de Chaves -->
    <div class="col-lg-8">
        <div class="glass-panel">
            <h3 class="section-title mb-4">Chaves Registradas</h3>

            @if (_isLoading && _apiKeys.Count == 0)
            {
                <div class="loading-container">
                    <div class="spinner-premium"></div>
                    <div class="loading-text">Carregando chaves...</div>
                </div>
            }
            else if (_apiKeys.Count == 0)
            {
                <div class="empty-state py-5 text-center">
                    <svg class="text-muted mb-3" viewBox="0 0 24 24" width="48" height="48"><path fill="currentColor" d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                    <h4 class="text-secondary">Nenhuma chave de API gerada</h4>
                    <p class="text-muted text-sm">Gere sua primeira chave de API no formulário lateral para integrar seu sistema.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-premium">
                        <thead>
                            <tr>
                                <th>Descrição</th>
                                <th>Hash (Identificador)</th>
                                <th>Data de Criação</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var key in _apiKeys)
                            {
                                <tr class="align-middle">
                                    <td><strong class="text-light">@key.Description</strong></td>
                                    <td><span class="font-mono text-secondary text-sm">@TruncateHash(key.KeyHash)</span></td>
                                    <td><span class="text-secondary text-sm">@key.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm", CultureInfo.InvariantCulture)</span></td>
                                    <td>
                                        @if (key.IsRevoked)
                                        {
                                            <span class="badge badge-danger">Revogada</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success">Ativa</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!key.IsRevoked)
                                        {
                                            <button class="btn btn-sm btn-outline-danger border-glass" @onclick="() => HandleRevoke(key.KeyHash)" title="Revogar esta chave imediatamente">
                                                Revogar
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted text-sm">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Gerador de Chaves -->
    <div class="col-lg-4">
        <div class="glass-panel">
            <h3 class="section-title mb-3">Gerar Nova Chave</h3>
            <p class="text-secondary text-sm mb-4">
                As chaves geradas dão acesso direto aos disparos de e-mail do seu Tenant. Guarde-as de forma segura.
            </p>

            @if (!string.IsNullOrWhiteSpace(_plainTextKeyGenerated))
            {
                <div class="alert-premium alert-premium-success flex-column align-items-start gap-2 mb-4">
                    <div class="d-flex align-items-center gap-2">
                        <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                        <strong>Chave gerada com sucesso!</strong>
                    </div>
                    <p class="text-sm text-light mb-2">Cópia única: ela **NÃO** poderá ser mostrada novamente.</p>
                    <div class="key-display w-100 p-2 font-mono text-center text-light bg-dark rounded border-glass mb-2 select-all">
                        @_plainTextKeyGenerated
                    </div>
                    <button class="btn btn-sm btn-premium w-100" @onclick="CopyKeyToClipboard">
                        @(_copied ? "Copiado!" : "Copiar Chave")
                    </button>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert-premium alert-premium-danger mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <EditForm Model="@_generateModel" OnValidSubmit="HandleGenerate">
                <DataAnnotationsValidator />

                <div class="form-group-premium">
                    <label for="description">Descrição da Chave</label>
                    <InputText id="description" class="input-premium" @bind-Value="_generateModel.Description" placeholder="ex: Integração Webhook CRM" />
                    <ValidationMessage For="@(() => _generateModel.Description)" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn-premium w-100" disabled="@_isLoading">
                        Gerar Chave de Acesso
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Inject] private HttpClient HttpClient { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    private List<ApiKeyDetailsResponse> _apiKeys = new();
    private readonly LocalGenerateKeyModel _generateModel = new();
    private bool _isLoading = false;
    private string? _plainTextKeyGenerated;
    private bool _copied = false;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadApiKeys();
    }

    private async Task LoadApiKeys()
    {
        _isLoading = true;
        try
        {
            var response = await HttpClient.GetAsync("api/tenants/api-keys");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ClientResult<List<ApiKeyDetailsResponse>>>();
                if (result != null && result.IsSuccess && result.Value != null)
                {
                    _apiKeys = result.Value;
                }
            }
        }
        catch
        {
            // Silencioso
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleGenerate()
    {
        _isLoading = true;
        _errorMessage = null;
        _plainTextKeyGenerated = null;
        _copied = false;

        try
        {
            var request = new GenerateApiKeyRequest(_generateModel.Description);
            var response = await HttpClient.PostAsJsonAsync("api/tenants/api-keys", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ClientResult<ApiKeyResponse>>();
                if (result != null && result.IsSuccess && result.Value != null)
                {
                    _plainTextKeyGenerated = result.Value.PlainTextKey;
                    _generateModel.Description = "";
                    await LoadApiKeys(); // Recarrega tabela
                }
                else
                {
                    _errorMessage = result?.Error?.Message ?? "Erro ao gerar chave de API.";
                }
            }
            else
            {
                _errorMessage = "Erro ao enviar requisição de geração.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erro de rede: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleRevoke(string keyHash)
    {
        try
        {
            var response = await HttpClient.DeleteAsync($"api/tenants/api-keys/{keyHash}");
            if (response.IsSuccessStatusCode)
            {
                await LoadApiKeys();
            }
        }
        catch
        {
            // Silencioso
        }
    }

    private async Task CopyKeyToClipboard()
    {
        if (!string.IsNullOrEmpty(_plainTextKeyGenerated))
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _plainTextKeyGenerated);
            _copied = true;
        }
    }

    private string TruncateHash(string hash)
    {
        if (string.IsNullOrEmpty(hash) || hash.Length < 12)
        {
            return hash;
        }
        return $"{hash[..6]}...{hash[^6..]}";
    }

    public class LocalGenerateKeyModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "A descrição é obrigatória.")]
        [System.ComponentModel.DataAnnotations.StringLength(50, MinimumLength = 3, ErrorMessage = "A descrição deve ter entre 3 e 50 caracteres.")]
        public string Description { get; set; } = string.Empty;
    }
}

<style>
.font-mono {
    font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
.select-all {
    user-select: all;
    -webkit-user-select: all;
}
.key-display {
    background: rgba(15, 23, 42, 0.9) !important;
    word-break: break-all;
    font-size: 0.95rem;
}
.table-premium {
    width: 100%;
    margin-bottom: 0;
    color: var(--text-primary);
    border-collapse: collapse;
}
.table-premium th {
    font-family: var(--font-heading);
    color: var(--text-secondary);
    font-weight: 600;
    border-bottom: 1px solid var(--border-glass);
    padding: 1rem;
}
.table-premium td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
.table-premium tbody tr:hover {
    background: rgba(255, 255, 255, 0.02);
}
.badge {
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    display: inline-block;
}
.badge-success {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.25);
}
.badge-danger {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.25);
}
.border-glass {
    border: 1px solid var(--border-glass);
}
.w-100 {
    width: 100%;
}
</style>
