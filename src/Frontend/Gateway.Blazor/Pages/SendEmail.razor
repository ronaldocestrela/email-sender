@page "/send-email"
@attribute [Authorize]
@using Gateway.Blazor.Models

<PageTitle>Disparar E-mail - Email Sender</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <h1 class="page-title">Disparar E-mail</h1>
        <p class="text-secondary">Simule e teste o envio assíncrono de e-mails com variáveis dinâmicas</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="glass-panel">
            <h3 class="section-title mb-4">Parâmetros do E-mail</h3>

            @if (!string.IsNullOrWhiteSpace(_successMessage))
            {
                <div class="alert-premium alert-premium-success mb-4">
                    <svg viewBox="0 0 24 24" width="20" height="20" class="me-2"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                    <span>@_successMessage</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert-premium alert-premium-danger mb-4">
                    <svg viewBox="0 0 24 24" width="20" height="20" class="me-2"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                    <span>@_errorMessage</span>
                </div>
            }

            <EditForm Model="@_sendModel" OnValidSubmit="HandleSend">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6 form-group-premium">
                        <label for="to">Destinatário</label>
                        <InputText id="to" class="input-premium" @bind-Value="_sendModel.To" placeholder="cliente@destino.com" />
                        <ValidationMessage For="@(() => _sendModel.To)" />
                    </div>

                    <div class="col-md-6 form-group-premium">
                        <label for="senderDomain">Domínio Remetente Autorizado</label>
                        <InputText id="senderDomain" class="input-premium" @bind-Value="_sendModel.SenderDomain" placeholder="meudominio.com" />
                        <ValidationMessage For="@(() => _sendModel.SenderDomain)" />
                    </div>
                </div>

                <div class="form-group-premium mt-3">
                    <label for="subject">Assunto (suporta variáveis como {{nome}})</label>
                    <InputText id="subject" class="input-premium" @bind-Value="_sendModel.Subject" placeholder="Bem-vindo ao sistema, {{nome}}!" />
                    <ValidationMessage For="@(() => _sendModel.Subject)" />
                </div>

                <div class="form-group-premium mt-3">
                    <label for="body">Corpo do E-mail (HTML permitido)</label>
                    <InputTextArea id="body" class="input-premium font-mono" rows="8" @bind-Value="_sendModel.Body" placeholder="Olá {{nome}}, sua conta foi criada com sucesso! Código: {{codigo}}" />
                    <ValidationMessage For="@(() => _sendModel.Body)" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn-premium d-inline-flex align-items-center gap-2" disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span>Enviando para Fila...</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                            <span>Disparar E-mail</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Variáveis de Template -->
    <div class="col-lg-4">
        <div class="glass-panel h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="section-title mb-0">Variáveis de Template</h3>
                <button class="btn btn-sm btn-premium-outline d-flex align-items-center gap-1" @onclick="AddVariable">
                    <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                    Nova
                </button>
            </div>
            
            <p class="text-secondary text-sm mb-4">
                Essas variáveis substituirão os placeholders correspondentes (ex: <code>{{chave}}</code>) contidos no assunto e no corpo do e-mail.
            </p>

            @if (_variables.Count == 0)
            {
                <div class="empty-state py-4 text-center">
                    <span class="text-muted text-sm">Nenhuma variável adicionada.</span>
                </div>
            }
            else
            {
                <div class="variables-list">
                    @for (int i = 0; i < _variables.Count; i++)
                    {
                        var index = i;
                        <div class="variable-row mb-3 d-flex gap-2 align-items-center">
                            <input type="text" class="input-premium font-mono text-sm py-2" placeholder="Chave" @bind="_variables[index].Key" />
                            <input type="text" class="input-premium font-mono text-sm py-2" placeholder="Valor" @bind="_variables[index].Value" />
                            <button class="btn btn-outline-danger border-glass py-2" @onclick="() => RemoveVariable(index)">
                                <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private HttpClient HttpClient { get; set; } = default!;

    private readonly LocalSendEmailModel _sendModel = new();
    private readonly List<KeyValuePairItem> _variables = new()
    {
        new KeyValuePairItem { Key = "nome", Value = "Ronald" },
        new KeyValuePairItem { Key = "codigo", Value = "982173" }
    };

    private bool _isLoading = false;
    private string? _successMessage;
    private string? _errorMessage;

    private void AddVariable()
    {
        _variables.Add(new KeyValuePairItem());
    }

    private void RemoveVariable(int index)
    {
        if (index >= 0 && index < _variables.Count)
        {
            _variables.RemoveAt(index);
        }
    }

    private async Task HandleSend()
    {
        _isLoading = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            // Converte a lista interna de variáveis para dicionário
            var variablesDict = new Dictionary<string, string>();
            foreach (var item in _variables)
            {
                if (!string.IsNullOrWhiteSpace(item.Key))
                {
                    variablesDict[item.Key.Trim()] = item.Value.Trim();
                }
            }

            var request = new SendEmailRequest(
                _sendModel.To,
                _sendModel.Subject,
                _sendModel.Body,
                _sendModel.SenderDomain,
                variablesDict
            );

            var response = await HttpClient.PostAsJsonAsync("api/emails/send", request);

            if (response.IsSuccessStatusCode)
            {
                _successMessage = "Solicitação de disparo aceita com sucesso e enviada para a fila de processamento.";
                // Reseta os campos exceto domínio
                _sendModel.To = "";
                _sendModel.Subject = "";
                _sendModel.Body = "";
            }
            else
            {
                var apiResult = await response.Content.ReadFromJsonAsync<ClientResult>();
                _errorMessage = apiResult?.Error?.Message ?? "Falha ao solicitar disparo de e-mail.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erro de rede ao enviar solicitação: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public class LocalSendEmailModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O destinatário é obrigatório.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Insira um e-mail válido.")]
        public string To { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O domínio do remetente é obrigatório.")]
        public string SenderDomain { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O assunto é obrigatório.")]
        public string Subject { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O corpo do e-mail é obrigatório.")]
        public string Body { get; set; } = string.Empty;
    }

    public class KeyValuePairItem
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}

<style>
.font-mono {
    font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
.variable-row input {
    flex: 1;
}
.border-glass {
    border: 1px solid var(--border-glass);
}
.h-100 {
    height: 100%;
}
</style>
