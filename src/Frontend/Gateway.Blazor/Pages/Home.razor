@page "/"
@attribute [Authorize]
@using Gateway.Blazor.Models
@using System.Globalization

<PageTitle>Dashboard - Email Sender</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="text-secondary">Visão geral dos disparos de e-mail e métricas de envio</p>
    </div>
    <div>
        <button class="btn btn-premium-outline d-inline-flex align-items-center gap-2" @onclick="LoadData">
            <svg viewBox="0 0 24 24" width="16" height="16" class="@(_isLoading ? "spinner-premium" : "")"><path fill="currentColor" d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
            Atualizar
        </button>
    </div>
</div>

@if (_isLoading && _emailHistories.Count == 0)
{
    <div class="loading-container">
        <div class="spinner-premium"></div>
        <div class="loading-text">Carregando métricas e histórico...</div>
    </div>
}
else
{
    <!-- Métricas Superiores -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-panel metric-card">
                <div class="metric-icon metric-icon-blue">
                    <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                </div>
                <div class="metric-content">
                    <span class="metric-label">Total Solicitado</span>
                    <h2 class="metric-value">@_totalSent</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel metric-card">
                <div class="metric-icon metric-icon-green">
                    <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg>
                </div>
                <div class="metric-content">
                    <span class="metric-label">Disparos com Sucesso</span>
                    <h2 class="metric-value">@_successSent</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel metric-card">
                <div class="metric-icon metric-icon-red">
                    <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                </div>
                <div class="metric-content">
                    <span class="metric-label">Falhas de Envio</span>
                    <h2 class="metric-value">@_failedSent</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros & Histórico -->
    <div class="glass-panel">
        <div class="row g-3 align-items-center mb-4">
            <div class="col-md-6">
                <h3 class="section-title mb-0">Histórico de Disparos</h3>
            </div>
            <div class="col-md-4 col-sm-8">
                <div class="search-input-wrapper">
                    <svg viewBox="0 0 24 24" width="16" height="16" class="search-icon"><path fill="currentColor" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                    <input type="text" class="input-premium" placeholder="Buscar por destinatário..." @bind-value="_searchQuery" @bind-value:event="oninput" />
                </div>
            </div>
            <div class="col-md-2 col-sm-4">
                <select class="input-premium" @bind="_statusFilter">
                    <option value="All">Todos</option>
                    <option value="Success">Sucesso</option>
                    <option value="Failed">Falha</option>
                </select>
            </div>
        </div>

        @if (FilteredHistories.Count == 0)
        {
            <div class="empty-state py-5 text-center">
                <svg class="text-muted mb-3" viewBox="0 0 24 24" width="48" height="48"><path fill="currentColor" d="M22 16V4c0-1.1-.9-2-2-2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2zm-11-4l2.03 2.71L16 11l4 5H8l3-4zM2 6v14c0 1.1.9 2 2 2h14v-2H4V6H2z"/></svg>
                <h4 class="text-secondary">Nenhum registro encontrado</h4>
                <p class="text-muted text-sm mb-0">Dispare e-mails ou mude os filtros para ver logs históricos.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-premium">
                    <thead>
                        <tr>
                            <th>Destinatário</th>
                            <th>Assunto</th>
                            <th>Domínio Remetente</th>
                            <th>Data do Disparo</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var history in FilteredHistories)
                        {
                            <tr class="align-middle">
                                <td><span class="text-light font-mono font-medium">@history.To</span></td>
                                <td>@history.Subject</td>
                                <td><span class="text-secondary font-mono text-sm">@history.SenderDomain</span></td>
                                <td><span class="text-secondary text-sm">@history.SentAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss", CultureInfo.InvariantCulture)</span></td>
                                <td>
                                    @if (history.IsSuccess)
                                    {
                                        <span class="badge badge-success">Enviado</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger cursor-pointer" title="@history.ErrorMessage">
                                            Falhou
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    [Inject] private HttpClient HttpClient { get; set; } = default!;

    private List<EmailHistoryResponse> _emailHistories = new();
    private bool _isLoading = false;
    private string _searchQuery = "";
    private string _statusFilter = "All";

    // Métricas calculadas
    private int _totalSent => _emailHistories.Count;
    private int _successSent => _emailHistories.Count(h => h.IsSuccess);
    private int _failedSent => _emailHistories.Count(h => !h.IsSuccess);

    private List<EmailHistoryResponse> FilteredHistories
    {
        get
        {
            var query = _emailHistories.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                query = query.Where(h => h.To.Contains(_searchQuery.Trim(), StringComparison.OrdinalIgnoreCase));
            }

            if (_statusFilter == "Success")
            {
                query = query.Where(h => h.IsSuccess);
            }
            else if (_statusFilter == "Failed")
            {
                query = query.Where(h => !h.IsSuccess);
            }

            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            var response = await HttpClient.GetAsync("api/emails/history");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ClientResult<List<EmailHistoryResponse>>>();
                if (result != null && result.IsSuccess && result.Value != null)
                {
                    _emailHistories = result.Value;
                }
            }
        }
        catch
        {
            // Silencioso ou reportar erro
        }
        finally
        {
            _isLoading = false;
        }
    }
}

<style>
.metric-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: 16px;
}

.metric-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.metric-icon-blue {
    background: rgba(99, 102, 241, 0.15);
    color: var(--primary);
}

.metric-icon-green {
    background: rgba(16, 185, 129, 0.15);
    color: var(--success);
}

.metric-icon-red {
    background: rgba(239, 68, 68, 0.15);
    color: var(--danger);
}

.metric-content {
    display: flex;
    flex-direction: column;
}

.metric-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: var(--font-heading);
}

.metric-value {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 700;
}

.section-title {
    font-size: 1.25rem;
    font-family: var(--font-heading);
}

.search-input-wrapper {
    position: relative;
    width: 100%;
}

.search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
}

.search-input-wrapper .input-premium {
    padding-left: 36px;
}
.font-medium {
    font-weight: 500;
}

.cursor-pointer {
    cursor: pointer;
}
</style>
